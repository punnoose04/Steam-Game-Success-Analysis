      <aliases enabled='yes' />
      <column caption='Price Revenue Quadrant' datatype='string' name='[Calculation_0539884568150016]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([reference_price_usd 1])&#13;&#10;OR ISNULL([revenue_base 1])&#13;&#10;THEN &quot;Missing Data&quot;&#13;&#10;&#13;&#10;ELSEIF [reference_price_usd 1] &lt;&#13;&#10;    { FIXED : MEDIAN([reference_price_usd 1]) }&#13;&#10;AND [revenue_base 1] &gt;=&#13;&#10;    { FIXED : MEDIAN([revenue_base 1]) }&#13;&#10;THEN &quot;Lower Price / Higher Revenue&quot;&#13;&#10;&#13;&#10;ELSEIF [reference_price_usd 1] &gt;=&#13;&#10;    { FIXED : MEDIAN([reference_price_usd 1]) }&#13;&#10;AND [revenue_base 1] &gt;=&#13;&#10;    { FIXED : MEDIAN([revenue_base 1]) }&#13;&#10;THEN &quot;Higher Price / Higher Revenue&quot;&#13;&#10;&#13;&#10;ELSEIF [reference_price_usd 1] &lt;&#13;&#10;    { FIXED : MEDIAN([reference_price_usd 1]) }&#13;&#10;AND [revenue_base 1] &lt;&#13;&#10;    { FIXED : MEDIAN([revenue_base 1]) }&#13;&#10;THEN &quot;Lower Price / Lower Revenue&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Higher Price / Lower Revenue&quot;&#13;&#10;END' />
      </column>
      <column caption='Genre Revenue per Game' datatype='real' name='[Calculation_0539884587806722]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [genre] :&#13;&#10;    SUM([attributed_revenue_base]) / COUNTD([game_key])&#13;&#10;}' />
      </column>
      <column caption='Adaptive Revenue Label' datatype='string' name='[Calculation_2066281293545472]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF ABS(SUM([attributed_revenue_base])) &gt;= 1000000000 THEN&#13;&#10;    &quot;$&quot; +&#13;&#10;    STR(ROUND(SUM([attributed_revenue_base]) / 1000000000, 1)) +&#13;&#10;    &quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF ABS(SUM([attributed_revenue_base])) &gt;= 1000000 THEN&#13;&#10;    &quot;$&quot; +&#13;&#10;    STR(ROUND(SUM([attributed_revenue_base]) / 1000000, 1)) +&#13;&#10;    &quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF ABS(SUM([attributed_revenue_base])) &gt;= 1000 THEN&#13;&#10;    &quot;$&quot; +&#13;&#10;    STR(ROUND(SUM([attributed_revenue_base]) / 1000, 1)) +&#13;&#10;    &quot;K&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;$&quot; +&#13;&#10;    STR(ROUND(SUM([attributed_revenue_base]), 0))&#13;&#10;END' />
      </column>
