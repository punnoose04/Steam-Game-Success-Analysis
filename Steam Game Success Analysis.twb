      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Price of game vs. Revenue </run>
            <run>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Steam Games – Game Level' name='federated.0wnwtnq08wl3561a7rxsn082pmy5' />
          </datasources>
          <datasource-dependencies datasource='federated.0wnwtnq08wl3561a7rxsn082pmy5'>
            <column caption='Price Revenue Quadrant' datatype='string' name='[Calculation_0539884568150016]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([reference_price_usd])&#13;&#10;OR ISNULL([revenue_base])&#13;&#10;THEN &quot;Missing Data&quot;&#13;&#10;&#13;&#10;ELSEIF [reference_price_usd] &lt;&#13;&#10;    { FIXED : MEDIAN([reference_price_usd]) }&#13;&#10;AND [revenue_base] &gt;=&#13;&#10;    { FIXED : MEDIAN([revenue_base]) }&#13;&#10;THEN &quot;Lower Price / Higher Revenue&quot;&#13;&#10;&#13;&#10;ELSEIF [reference_price_usd] &gt;=&#13;&#10;    { FIXED : MEDIAN([reference_price_usd]) }&#13;&#10;AND [revenue_base] &gt;=&#13;&#10;    { FIXED : MEDIAN([revenue_base]) }&#13;&#10;THEN &quot;Higher Price / Higher Revenue&quot;&#13;&#10;&#13;&#10;ELSEIF [reference_price_usd] &lt;&#13;&#10;    { FIXED : MEDIAN([reference_price_usd]) }&#13;&#10;AND [revenue_base] &lt;&#13;&#10;    { FIXED : MEDIAN([revenue_base]) }&#13;&#10;THEN &quot;Lower Price / Lower Revenue&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    &quot;Higher Price / Lower Revenue&quot;&#13;&#10;END' />
            </column>
            <column-instance column='[primary_genre]' derivation='Attribute' name='[attr:primary_genre:nk]' pivot='key' type='nominal' />
            <column-instance column='[title]' derivation='Attribute' name='[attr:title:nk]' pivot='key' type='nominal' />
            <column-instance column='[owners_midpoint]' derivation='Avg' name='[avg:owners_midpoint:qk]' pivot='key' type='quantitative' />
