    <worksheet name='Sheet 13'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Top Genres by Average Revenue per Game</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Steam PostgreSQL – Genre Model' name='federated.07jxsaq1do5d76182lzur0t9eogd' />
          </datasources>
          <datasource-dependencies datasource='federated.07jxsaq1do5d76182lzur0t9eogd'>
            <column caption='Genre Revenue per Game' datatype='real' name='[Calculation_0539884587806722]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [genre] :&#13;&#10;    SUM([attributed_revenue_base]) / COUNTD([game_key])&#13;&#10;}' />
